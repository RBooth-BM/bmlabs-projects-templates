# =============================================================================
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO - .env.example
# =============================================================================
# 
# Este archivo sirve como plantilla para las variables de entorno necesarias
# en el proyecto API .NET Template.
#
# INSTRUCCIONES DE USO:
# 1. Copia este archivo como '.env' en el directorio raíz del proyecto
#    cp .env.example .env
#
# 2. Completa los valores reales de las variables según tu ambiente
#
# 3. El archivo .env NO debe ser commiteado al repositorio por seguridad
#    (ya está incluido en .gitignore)
#
# 4. Cada desarrollador debe tener su propio archivo .env con sus configuraciones
#
# NOTA: Los valores mostrados aquí son solo ejemplos y placeholders.
#       NUNCA pongas valores reales de producción en este archivo.
# =============================================================================

# =============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================================================

# Entorno de ejecución (Development, Staging, Production)
# ASPNETCORE_ENVIRONMENT=Development

# URLs donde la aplicación escuchará requests
# ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# Connection String para base de datos principal
# Ejemplo SQL Server:
# ConnectionStrings__DefaultConnection=Server=localhost;Database=YourApiDb;Trusted_Connection=true;TrustServerCertificate=true;

# Ejemplo PostgreSQL:
# ConnectionStrings__DefaultConnection=Host=localhost;Database=your_api_db;Username=postgres;Password=your_password

# Ejemplo MySQL:
# ConnectionStrings__DefaultConnection=Server=localhost;Database=your_api_db;Uid=root;Pwd=your_password;

# =============================================================================
# CONFIGURACIÓN DE AUTHENTICATION Y AUTHORIZATION
# =============================================================================

# JWT Configuration
# JWT__SecretKey=your-super-secret-key-here-minimum-32-characters
# JWT__Issuer=your-api-name
# JWT__Audience=your-api-audience
# JWT__ExpirationMinutes=60

# OAuth/OpenID Connect (si aplica)
# Authentication__Authority=https://your-identity-provider.com
# Authentication__ClientId=your-client-id
# Authentication__ClientSecret=your-client-secret

# =============================================================================
# CONFIGURACIÓN DE SERVICIOS EXTERNOS
# =============================================================================

# API Keys para servicios externos
# ExternalServices__ServiceA__ApiKey=your-service-a-api-key
# ExternalServices__ServiceA__BaseUrl=https://api.servicea.com

# Configuración de Email (si aplica)
# Email__SmtpServer=smtp.gmail.com
# Email__SmtpPort=587
# Email__Username=your-email@domain.com
# Email__Password=your-email-password
# Email__FromAddress=noreply@yourdomain.com

# =============================================================================
# CONFIGURACIÓN DE AZURE/CLOUD (si aplica)
# =============================================================================

# Azure Storage
# AzureStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey

# Azure Key Vault
# AzureKeyVault__VaultUrl=https://your-keyvault.vault.azure.net/

# =============================================================================
# CONFIGURACIÓN DE LOGGING Y MONITORING
# =============================================================================

# Application Insights (si aplica)
# ApplicationInsights__InstrumentationKey=your-instrumentation-key

# Serilog configuración (si aplica)
# Serilog__MinimumLevel=Information
# Serilog__WriteTo__Console__Enabled=true

# =============================================================================
# CONFIGURACIÓN DE REDIS/CACHING (si aplica)
# =============================================================================

# Redis connection
# Redis__ConnectionString=localhost:6379
# Redis__Database=0

# =============================================================================
# CONFIGURACIÓN DE CORS (si aplica)
# =============================================================================

# URLs permitidas para CORS (separadas por punto y coma)
# Cors__AllowedOrigins=http://localhost:3000;https://your-frontend-domain.com

# =============================================================================
# CONFIGURACIÓN DE DESARROLLO
# =============================================================================

# Habilitar Swagger en producción (no recomendado)
# EnableSwaggerInProduction=false

# Seed de datos de desarrollo
# SeedDevelopmentData=true

# =============================================================================
# VARIABLES PERSONALIZADAS DEL PROYECTO
# =============================================================================

# Agrega aquí las variables específicas de tu proyecto
# CustomSetting__Feature1__Enabled=true
# CustomSetting__MaxItemsPerPage=50
# CustomSetting__TimeoutSeconds=30